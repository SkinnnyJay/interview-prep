{
  "name": "search-algorithms-examples",
  "version": "1.0.0",
  "description": "Implementation of various search algorithms without external libraries",
  "main": "dist/server.js",
  "type": "module",
  "author": "Jonathan (https://github.com/SkinnnyJay)",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "jest --config jest.config.cjs --detectOpenHandles --testTimeout=90000",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage --testTimeout=90000",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix && npm run format",
    "format": "prettier --write 'src/**/*.{ts,js,json}' '*.md'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json}' '*.md'",
    "openapi": "tsx src/generate-openapi.ts"
  },
  "dependencies": {
    "fastify": "^5.7.4",
    "@fastify/cors": "^11.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/jest": "^29.5.5",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "tsx": "^4.6.2",
    "pino-pretty": "^11.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  }
}
