{
  "name": "autocomplete-api-example",
  "version": "1.0.0",
  "description": "Full-stack autocomplete API with frontend and backend components",
  "main": "dist/server.js",
  "author": "Jonathan (https://github.com/SkinnnyJay)",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "tsc && npm run build:frontend",
    "start": "node dist/server.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "test": "jest --config jest.config.js --detectOpenHandles --testTimeout=90000",
    "test:watch": "jest --config jest.config.js --watch",
    "setup:frontend": "cd frontend && npm install",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix && npm run format",
    "format": "prettier --write 'src/**/*.{ts,js,json}' '*.md'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json}' '*.md'",
    "openapi": "tsx src/generate-openapi.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "fastify": "^5.7.4",
    "fuse.js": "^7.0.0",
    "lodash": "^4.17.21",
    "lodash.debounce": "^4.0.8",
    "redis": "^4.6.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/lodash.debounce": "^4.0.7",
    "@types/node": "^20.8.0",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsx": "^4.6.2",
    "typescript": "^5.2.2"
  }
}
