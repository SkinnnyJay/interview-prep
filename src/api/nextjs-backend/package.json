{
  "name": "nextjs-backend-example",
  "version": "1.0.0",
  "description": "NextJS backend application with CRUD operations, dependency injection, and best practices",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3034",
    "build": "prisma generate && next build",
    "start": "next start -p 3034",
    "lint": "next lint",
    "test": "jest --testTimeout=90000",
    "test:watch": "jest --watch --testTimeout=90000",
    "test:coverage": "jest --coverage --testTimeout=90000",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "next": "^15.5.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@prisma/client": "^5.6.0",
    "prisma": "^5.6.0",
    "zod": "^3.22.4",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "jose": "^5.1.3",
    "winston": "^3.11.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.2.2",
    "inversify": "^6.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/uuid": "^9.0.7",
    "@types/jest": "^29.5.5",
    "typescript": "^5.2.2",
    "eslint": "^8.52.0",
    "eslint-config-next": "^15.5.12",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.0",
    "sqlite3": "^5.1.6"
  },
  "overrides": {
    "glob": "^11.0.0",
    "tar": "^7.5.10",
    "@tootallnate/once": "^3.0.1"
  }
}
