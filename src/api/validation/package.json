{
  "name": "validation-api",
  "version": "1.0.0",
  "description": "A comprehensive API validation system using Zod with advanced patterns and error handling",
  "main": "../../../dist/api/validation/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "node ../../../dist/api/validation/server.js",
    "build": "tsc",
    "test": "jest src/validation.test.ts --detectOpenHandles --testTimeout=90000",
    "test:watch": "jest src/validation.test.ts --watch",
    "test:coverage": "jest src/validation.test.ts --coverage --testTimeout=90000",
    "test:integration": "jest src/integration.test.ts",
    "clean": "rm -rf ../../../dist/api/validation",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix && npm run format",
    "format": "prettier --write 'src/**/*.{ts,js,json}' '*.md'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json}' '*.md'",
    "openapi": "npm run build && node ../../../dist/api/validation/generate-openapi.js"
  },
  "keywords": [
    "validation",
    "zod",
    "api",
    "fastify",
    "typescript",
    "schema",
    "type-safety",
    "error-handling"
  ],
  "author": "Jonathan (https://github.com/SkinnnyJay)",
  "license": "MIT",
  "dependencies": {
    "fastify": "^5.7.4",
    "fastify-plugin": "^4.5.1",
    "zod": "^3.22.4",
    "fastify-zod": "^1.4.0",
    "tsx": "^4.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "jest": {
    "preset": "ts-jest/presets/default",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.test.ts",
      "!src/server.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": false,
          "tsconfig": {
            "module": "CommonJS"
          }
        }
      ]
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
