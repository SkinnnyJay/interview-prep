                "password": {
                  "type": "string",
                  "minLength": 8
                },
                "firstName": {
                  "type": "string",
                  "minLength": 1
                },
                "lastName": {
                  "type": "string",
                  "minLength": 1
                },
                "role": {
                  "type": "string",
                  "enum": [
                    "admin",
                    "manager",
                    "user",
                    "guest"
                  ]
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Default Response",
            "schema": {
              "type": "object",
              "properties": {
                "success": {
                  "type": "boolean"
                },
