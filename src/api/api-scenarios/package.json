{
  "name": "api-scenarios-examples",
  "version": "1.0.0",
  "description": "Comprehensive API scenarios demonstrating CRUD, streaming, and advanced patterns",
  "main": "dist/server.js",
  "author": "SkinnnyJay (https://github.com/SkinnnyJay)",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test": "jest --config ./jest.config.js --detectOpenHandles --testTimeout=120000",
    "test:watch": "jest --config ./jest.config.js --watch",
    "test:coverage": "jest --config ./jest.config.js --coverage --testTimeout=120000",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix && npm run format",
    "format": "prettier --write 'src/**/*.{ts,js,json}' '*.md'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json}' '*.md'",
    "openapi": "ts-node src/generate-openapi.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@fastify/websocket": "^11.2.0",
    "ajv": "^8.12.0",
    "bcrypt": "^6.0.0",
    "fastify": "^5.7.4",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.2.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.5",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/node": "^20.8.0",
    "@types/pg": "^8.10.7",
    "@types/supertest": "^2.0.15",
    "@types/uuid": "^9.0.6",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.2"
  }
}
