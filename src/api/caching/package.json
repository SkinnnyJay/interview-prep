{
  "name": "caching-api",
  "version": "1.0.0",
  "description": "A comprehensive caching system with multiple strategies supporting Redis and in-memory storage",
  "main": "../../../dist/api/caching/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "node ../../../dist/api/caching/server.js",
    "build": "tsc",
    "test": "jest src/cache.test.ts --detectOpenHandles --testTimeout=90000",
    "test:watch": "jest src/cache.test.ts --watch",
    "test:coverage": "jest src/cache.test.ts --coverage --testTimeout=90000",
    "test:performance": "jest src/performance-tests.ts",
    "clean": "rm -rf ../../../dist/api/caching",
    "redis:start": "docker run -d -p 6379:6379 --name redis-cache redis:alpine",
    "redis:stop": "docker stop redis-cache && docker rm redis-cache",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix && npm run format",
    "format": "prettier --write 'src/**/*.{ts,js,json}' '*.md'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json}' '*.md'",
    "openapi": "npm run build && node ../../../dist/api/caching/generate-openapi.js"
  },
  "keywords": [
    "caching",
    "api",
    "fastify",
    "redis",
    "typescript",
    "lru",
    "lfu",
    "ttl",
    "performance"
  ],
  "author": "Jonathan (https://github.com/SkinnnyJay)",
  "license": "MIT",
  "dependencies": {
    "fastify": "^5.7.4",
    "ioredis": "^5.3.2",
    "ioredis-mock": "^8.9.0",
    "tsx": "^4.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "jest": {
    "preset": "ts-jest/presets/default",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.test.ts",
      "!src/server.ts",
      "!src/performance-tests.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": false,
          "tsconfig": {
            "module": "CommonJS"
          }
        }
      ]
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
