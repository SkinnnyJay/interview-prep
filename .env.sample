# Root environment sample for the monorepo
# Copy to .env.local (or .env) and set values as needed. Do not commit secrets.

# -----------------------------------------------------------------------------
# Shared (used by multiple modules)
# -----------------------------------------------------------------------------

# JWT signing secret (security, api-scenarios, nextjs-backend, dependency-injection)
# Required in production. Use a long random string.
JWT_SECRET=""

# Redis (caching, rate-limiter, nextjs-backend when REDIS_URL is set)
# Leave unset to use in-memory/mock backends. Set for production or local Redis.
# REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# Optional overrides (defaults work for local dev)
# -----------------------------------------------------------------------------

# NODE_ENV="development"
# PORT=3000
# HOST="0.0.0.0"
# LOG_LEVEL="info"

# -----------------------------------------------------------------------------
# Module-specific samples
# -----------------------------------------------------------------------------
# nextjs-backend: see src/api/nextjs-backend/env.example
# Other modules use defaults or read from this file when present.
